# ─── NexaBid Backend — Production Environment ────────────────────
# Copy this to .env and fill in all values before deploying

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/nexabid
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/nexabid
MONGODB_URI=mongodb://mongo:27017/nexabid

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT (generate with: openssl rand -base64 64) ─────────────────
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ── Gmail SMTP ────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Gmail account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate a password for "Mail" → "Other (NexaBid)"
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Email Display ─────────────────────────────────────────────────
EMAIL_FROM_NAME=NexaBid
EMAIL_FROM_ADDRESS=noreply@nexabid.com

# ── OTP ───────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ── Frontend URLs (for CORS & emails) ────────────────────────────
CLIENT_URL=https://app.nexabid.com
MANUFACTURER_URL=https://mfr.nexabid.com
ADMIN_URL=https://admin.nexabid.com

# ── Razorpay ─────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... keys for testing, rzp_live_... for production
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# ── Optional: Sentry error tracking ──────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
